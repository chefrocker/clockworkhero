export interface LogEntry {
  id: number;
  title: string;
  exe_path?: string;
  created_at: string;
}

export interface Project {
  id: number;
  name: string;
  color: string;
}

export interface ColorEntry {
  name: string;
  color: string;
}

export interface WorkSession {
  id: number;
  project_id: number | null;
  description: string;
  start_time: string;
  end_time: string;
}

export interface ActivitySubEvent {
  time: string;
  title: string;
}

// NEU: Erweiterte Einstellungen
export interface AppSettings {
  workStart: string;      // "08:00"
  workEnd: string;        // "17:00"
  theme: string;          // "light"
  groupingThreshold: number; // Minuten (z.B. 5 oder 15)
}

export interface CalendarEvent {
  id: string;
  title: string;
  start: Date;
  end: Date;
  display?: string;
  backgroundColor?: string;
  extendedProps: {
    type: 'auto' | 'manual';
    order: number;
    fullTitle?: string;
    exePath?: string;
    appColor?: string;
    simpleName?: string;
    subEvents?: ActivitySubEvent[];
    dbId?: number;
    projectId?: number | null;
    projectName?: string;
    projectColor?: string;
    description?: string;
    isEditMode?: boolean;
  };
}
