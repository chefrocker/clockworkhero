{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "opener:default",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "fs:allow-create",
    "fs:allow-copy-file",
    "fs:allow-exists",
    "fs:allow-remove",
    "fs:allow-rename",
    
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "fs:scope-appdata-recursive"
  ]
}
