{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClockworkHero",
  "version": "0.9.5",
  "identifier": "com.chefrocker.clockworkhero",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ClockworkHero",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {},
      "nsis": {}
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg2QkNCN0ExNzY3MUE1RDUKUldUVnBYRjJvYmU4aG1rMzR0amdWQWlWVStIRFBwNkZGVmJJOHY4cjJESEowUDRJeFNRYkVubUEK",
      "endpoints": [
        "https://github.com/DEIN-GITHUB-USER/ClockworkHero/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}